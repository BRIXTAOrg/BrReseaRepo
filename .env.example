# Local infrastructure started by `docker compose up -d`
DATABASE_URL=postgresql://brixta:brixta@localhost:5432/brixta
REDIS_URL=redis://localhost:6379/0

# Local artifacts are simplest. Change to `minio` to use the included service.
ARTIFACT_BACKEND=local
MINIO_ENDPOINT=localhost:9000
MINIO_CONSOLE_URL=http://localhost:9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-local-password
MINIO_BUCKET=brixta
MINIO_SECURE=false

# Embeddings and parsing
EMBEDDING_PLUGIN=sentence-transformers
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
BRIXTA_DOCLING_DEVICE=cpu
BRIXTA_DOCLING_THREADS=4

# Browser-visible URLs
BRIXTA_API_PUBLIC_URL=http://localhost:8000
BRIXTA_DASHBOARD_PUBLIC_URL=http://localhost:3000

# The local ChatGPT CLI overrides these values after creating an HTTPS tunnel.
BRIXTA_MCP_PUBLIC_URL=http://localhost:8001/mcp
BRIXTA_MCP_AUTH_MODE=none
BRIXTA_MCP_TENANT_ID=default
BRIXTA_CHATGPT_DISTRIBUTION=developer
BRIXTA_CHATGPT_CONNECT_URL=https://chatgpt.com/plugins

# Simulation workers
CALCULIX_EXECUTABLE=ccx
OPENFOAM_BLOCKMESH_EXECUTABLE=blockMesh
OPENFOAM_CHECKMESH_EXECUTABLE=checkMesh
OPENFOAM_RUN_EXECUTABLE=foamRun
OPENFOAM_VTK_EXECUTABLE=foamToVTK
SIMULATION_TIMEOUT_SECONDS=1800

LOG_LEVEL=INFO
